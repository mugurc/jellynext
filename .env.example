# JellyNext environment variables — copy to .env.local and fill in.
# All variables are OPTIONAL; JellyNext runs with none of them set.

# Pre-fills the Jellyfin server address on the login screen.
# Leave unset to have users enter it themselves.
NEXT_PUBLIC_JELLYFIN_SERVER_URL=

# TMDb v3 API key — enables the optional "Discover" page (worldwide trending/new
# titles and title logos). Without it, the Discover tab is hidden entirely.
# Server-only; never exposed to the browser.
# Get one at https://developer.themoviedb.org/docs/getting-started
TMDB_API_KEY=
